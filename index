
<!DOCTYPE html>
<html lang="ms">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>RMS Event Coordinator</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore-compat.js"></script>
  
</head>

<body class="min-h-screen p-6">

<div class="max-w-7xl mx-auto">

  <div class="mb-8">
    <h1 class="text-4xl font-bold text-yellow-400">
      RMS Event Coordinator
    </h1>
    <p class="text-gray-400 mt-2">
      Live Performance Coordination Dashboard
    </p>
  </div>

  <div class="grid md:grid-cols-4 gap-4 mb-8">

    <div class="glass rounded-2xl p-5">
      <h2 class="text-gray-400 text-sm">Jumlah Perguruan</h2>
      <p id="totalPerguruan" class="text-3xl font-bold mt-2">0</p>
    </div>

    <div class="glass rounded-2xl p-5">
      <h2 class="text-gray-400 text-sm">Jumlah Persembahan</h2>
      <p id="totalPersembahan" class="text-3xl font-bold mt-2">0</p>
    </div>

    <div class="glass rounded-2xl p-5">
      <h2 class="text-gray-400 text-sm">Jumlah Pesilat</h2>
      <p id="totalPesilat" class="text-3xl font-bold mt-2">0</p>
    </div>

    <div class="glass rounded-2xl p-5">
      <h2 class="text-gray-400 text-sm">Kategori Aktif</h2>
      <p id="totalKategori" class="text-3xl font-bold mt-2">0</p>
    </div>

  </div>

  <div class="grid lg:grid-cols-3 gap-6">

    <div class="lg:col-span-1 glass rounded-2xl p-6">

      <h2 class="text-2xl font-bold mb-4 text-yellow-400">
        Tambah Persembahan
      </h2>

      <form id="performanceForm" class="space-y-4">

        <input
          type="text"
          id="guru"
          placeholder="Nama Guru"
          class="w-full bg-black/40 border border-gray-700 rounded-xl p-3"
          required
        />

        <input
          type="text"
          id="perguruan"
          placeholder="Nama Perguruan"
          class="w-full bg-black/40 border border-gray-700 rounded-xl p-3"
          required
        />

        <select
          id="kategori"
          class="w-full bg-black/40 border border-gray-700 rounded-xl p-3"
          required
        >
          <option value="">Pilih Kategori</option>
          <option>Seni Tari</option>
          <option>Tempur Kosong</option>
          <option>Tempur Belantan</option>
          <option>Tempur Parang</option>
          <option>Tempur Keris</option>
          <option>Lompatan Harimau</option>
          <option>Lompatan Gelung Api</option>
          <option>Pecah Genting</option>
        </select>

        <input
          type="number"
          id="pesilat"
          placeholder="Jumlah Pesilat"
          class="w-full bg-black/40 border border-gray-700 rounded-xl p-3"
          required
        />

        <textarea
          id="catatan"
          placeholder="Catatan Khas"
          class="w-full bg-black/40 border border-gray-700 rounded-xl p-3"
        ></textarea>

        <button
          type="submit"
          class="w-full bg-yellow-500 hover:bg-yellow-400 text-black font-bold py-3 rounded-xl transition"
        >
          Simpan Persembahan
        </button>

      </form>

    </div>

    <div class="lg:col-span-2 glass rounded-2xl p-6">

      <div class="flex justify-between items-center mb-5">
        <h2 class="text-2xl font-bold text-yellow-400">
          Live Performance List
        </h2>

        <button
          onclick="toggleFullscreen()"
          class="bg-red-600 hover:bg-red-500 px-4 py-2 rounded-xl"
        >
          Fullscreen Mode
        </button>
      </div>

      <div id="performanceList" class="space-y-4"></div>

    </div>

  </div>

</div>

<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore-compat.js"></script>

<script src="firebase.js"></script>
<script src="app.js"></script>

</body>
</html>

</body>
</html>